# ═══════════════════════════════════════════════════════════════
# CEO James — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Application ───
APP_NAME=ceo-james
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_PREFIX=/api/v1

# ─── Database (Supabase) ───
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# IMPORTANT: Use Session mode (port 5432), NOT Transaction mode (port 6543)
# Replace "postgresql://" with "postgresql+asyncpg://" for SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://postgres.[your-ref]:[your-password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_ECHO=false

# ─── Redis (Upstash) ───
# Get from: Upstash Console → Your Database → Details tab
REDIS_URL=rediss://default:[your-password]@[your-host].upstash.io:6379

# ─── Auth / JWT ───
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Encryption (AES-256-GCM for platform credentials) ───
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-base64-encoded-32-byte-key

# ─── AI Providers ───
# PROVIDER_MODE controls how CEO James talks to Claude + Gemini:
#   "cli" (default) = uses CLI tools with your existing subscriptions (free)
#                      Requires: `claude` CLI (Max sub) + `gemini` CLI (free tier)
#   "api" = uses SDK clients with API keys (pay-per-token)
PROVIDER_MODE=cli
# Only needed if PROVIDER_MODE=api
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ─── Website & App Building (Claude Code CLI) ───
# "template" = Python string templates (fast, free, no CLI needed)
# "claude_code" = Claude Code CLI generates real code (better quality, needs `claude` CLI)
WEBSITE_BUILDER_MODE=claude_code
APP_BUILDER_MODE=claude_code
CLAUDE_CODE_MAX_TURNS_WEBSITE=8
CLAUDE_CODE_MAX_TURNS_APP=15
CLAUDE_CODE_TIMEOUT=300

# ─── Promo Image Generation (Google Imagen 3) ───
# Used for AI-generated App Store screenshots
# Get from: Google AI Studio → API Keys
GOOGLE_IMAGEN_API_KEY=
PROMO_SCREENSHOT_COUNT=5
PROMO_DEFAULT_DEVICES=["iphone_6_7"]

# ─── Applyra ASO (App Store Optimization) ───
# Tracks keyword rankings, app scores, and competitors on App Store + Google Play
# Get from: https://www.applyra.io → Settings → API
APPLYRA_API_KEY=
APPLYRA_BASE_URL=https://www.applyra.io

# ─── Email Delivery ───
# "sendgrid" = SendGrid API, "smtp" = direct SMTP, "log" = dev mode (prints to console)
EMAIL_PROVIDER=log
EMAIL_FROM_ADDRESS=outreach@seojames.io
EMAIL_REPLY_TO=
# SendGrid (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
# SMTP (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
# Follow-up schedule (days after initial email)
FOLLOWUP_SCHEDULE_DAYS=[7,14,21]

# ─── OAuth (Google — for Analytics + Search Console) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── OAuth (Meta / Facebook) ───
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/v1/auth/meta/callback

# ─── OAuth (Twitter/X) ───
# Get from: console.x.com → Apps → Your App → Keys and Tokens
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:8000/api/v1/auth/twitter/callback

# ─── OAuth (TikTok) ───
# Get from: developers.tiktok.com → Manage Apps → Your App
# NOTE: TikTok requires HTTPS redirect URIs (no localhost)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://okeke.us/api/v1/auth/tiktok/callback

# ─── OAuth (LinkedIn) ───
# Get from: linkedin.com/developers/apps → Your App → Auth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/linkedin/callback

# ─── OAuth (Pinterest) ───
# Get from: developers.pinterest.com → My Apps → Your App → Configure
# Requires "Ads" access + "Organic content" access enabled on your app
# Scopes: boards:read, boards:write, pins:read, pins:write, user_accounts:read
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:8000/api/v1/platforms/callback/pinterest

# ─── Twilio (Call tracking, SMS, voice) ───
# Users connect their OWN Twilio account from the Connections page (Account SID + Auth Token).
# Credentials are stored encrypted per-business in connected_accounts — no server-level creds needed.
#
# REQUIRED for webhooks: Set WEBHOOK_BASE_URL so Twilio knows where to POST call events.
#   Local dev: use ngrok → ngrok http 8000 → copy the https:// URL
#   Production: your server's public domain (e.g. https://ceo-james.yourcompany.com)
#
WEBHOOK_BASE_URL=https://your-ngrok-or-domain-here.ngrok.io

# ─── Celery (uses same Upstash Redis) ───
CELERY_BROKER_URL=rediss://default:[your-password]@[your-host].upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:[your-password]@[your-host].upstash.io:6379

# ─── CORS ───
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
